{
  "name": "proxmox-mcps",
  "version": "0.1.0",
  "description": "MCP server for Proxmox VE — AI-driven QEMU VM and LXC container management",
  "license": "MIT",
  "author": "Oliver <ngocdd94@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngocdd/proxmox-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ngocdd/proxmox-mcp/issues"
  },
  "homepage": "https://github.com/ngocdd/proxmox-mcp#readme",
  "type": "module",
  "bin": {
    "proxmox-mcp": "dist/index.js",
    "proxmox-mcp-check-config": "dist/cli/check-config.js",
    "proxmox-mcp-print-tools": "dist/cli/print-tools.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example",
    ".mcp.json.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check-config": "tsx src/cli/check-config.ts",
    "print-tools": "tsx src/cli/print-tools.ts",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "PROXMOX_E2E=1 vitest run tests/integration"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.7",
    "better-sqlite3": "^12.11.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "p-retry": "^6.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "ssh2": "^1.16.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.17.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.12.0",
    "@typescript-eslint/parser": "^8.12.0",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.13.0",
    "nock": "^14.0.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
