# npm 11+ requires explicit per-package allowlist for install scripts.
# Without this, every `npm install` prints an `allow-scripts` warning.
#
# Trusted native packages (require build/install scripts):
allow-scripts[]=better-sqlite3
allow-scripts[]=ssh2
allow-scripts[]=cpu-features
# esbuild (transitive of vitest, tsx, vite) and fsevents (macOS file watcher)
allow-scripts[]=esbuild
allow-scripts[]=fsevents